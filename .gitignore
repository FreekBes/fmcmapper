# Dev artifacts
/build/
output*/

# Dependencies
node_modules/

# Usage artifacts
mcserver/
*/.DS_Store
.DS_Store

# MapColorDumpMod Gradle / build. Ignore everything under build/ EXCEPT the
# shipped mod jar (build/libs/mapcolor-dump-*.jar) so it can be distributed
# directly. A directory excluded with a trailing slash can't have children
# re-included, so build/ is excluded via /* and libs/ is carved back out.
MapColorDumpMod/.gradle/
MapColorDumpMod/build/*
!MapColorDumpMod/build/libs/
MapColorDumpMod/build/libs/*
!MapColorDumpMod/build/libs/mapcolor-dump-*.jar
MapColorDumpMod/build/libs/*-sources.jar
!MapColorDumpMod/gradle/wrapper/gradle-wrapper.jar

# MapColorDumpMod IDE
MapColorDumpMod/.idea/
MapColorDumpMod/*.iml
MapColorDumpMod/.vscode/
MapColorDumpMod/.settings/
MapColorDumpMod/.classpath
MapColorDumpMod/.project

# MapColorDumpMod Fabric loom
MapColorDumpMod/run/
